# Spring Boot Configuration
SPRING_APPLICATION_NAME=SEdu
SPRING_PROFILES_ACTIVE=docker

# MongoDB Configuration
SPRING_DATA_MONGODB_URI=mongodb://mongodb:27017/SEdu_db
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DATABASE=SEdu_db
MONGODB_USERNAME=
MONGODB_PASSWORD=

# Server Configuration
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/

# Swagger/OpenAPI Configuration
SPRINGDOC_SWAGGER_UI_ENABLED=true
SPRINGDOC_API_DOCS_PATH=/v3/api-docs
SPRINGDOC_SWAGGER_UI_PATH=/swagger-ui.html

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_MOBILEDEV=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_DATA_MONGODB=DEBUG

# Data Seeding
DATA_SEEDER_ENABLED=true
